generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TRAINER
  INSTITUTION
  PROGRAMME_MANAGER
  MONITORING_OFFICER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model User {
  id            String   @id @default(uuid())
  clerkUserId   String   @unique
  name          String
  role          Role
  institutionId String?
  institution   User?    @relation("InstitutionUsers", fields: [institutionId], references: [id])
  onboardedBy   User[]   @relation("InstitutionUsers")
  createdAt     DateTime @default(now())

  // Relations
  batches        Batch[]        @relation("InstitutionBatches")
  batchesTrained BatchTrainer[]
  batchesJoined  BatchStudent[]
  attendance     Attendance[]
  sessions       Session[]
}

model Batch {
  id            String   @id @default(uuid())
  name          String
  institutionId String
  institution   User     @relation("InstitutionBatches", fields: [institutionId], references: [id])
  inviteCode    String   @unique @default(uuid())
  createdAt     DateTime @default(now())

  // Relations
  trainers BatchTrainer[]
  students BatchStudent[]
  sessions Session[]
}

model BatchTrainer {
  batchId   String
  trainerId String
  batch     Batch  @relation(fields: [batchId], references: [id])
  trainer   User   @relation(fields: [trainerId], references: [id])

  @@id([batchId, trainerId])
}

model BatchStudent {
  batchId   String
  studentId String
  batch     Batch  @relation(fields: [batchId], references: [id])
  student   User   @relation(fields: [studentId], references: [id])

  @@id([batchId, studentId])
}

model Session {
  id        String   @id @default(uuid())
  batchId   String
  trainerId String
  title     String
  date      DateTime
  startTime String
  endTime   String
  createdAt DateTime @default(now())

  batch      Batch        @relation(fields: [batchId], references: [id])
  trainer    User         @relation(fields: [trainerId], references: [id])
  attendance Attendance[]
}

model Attendance {
  id        String           @id @default(uuid())
  sessionId String
  studentId String
  status    AttendanceStatus
  markedAt  DateTime         @default(now())

  session Session @relation(fields: [sessionId], references: [id])
  student User    @relation(fields: [studentId], references: [id])

  @@unique([sessionId, studentId])
}
